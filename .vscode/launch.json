{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "ts-node-dev",
      "runtimeArgs": ["--respawn", "--transpile-only"],
      "args": ["src/index.ts"],
      "cwd": "${workspaceFolder}/backend",
      "sourceMaps": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}
