DATABASE_URL="file:./dev.db"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-cryptographically-secure-random-256-bit-hex-string"

# Optional: if omitted, it can be set from Notifications UI and persisted there.
# TELEGRAM_BOT_TOKEN=""

# Optional Home Assistant OAuth overrides.
# If omitted, APP_URL is auto-detected at startup.
# HA_CLIENT_ID=""
# HA_CLIENT_SECRET=""
# APP_URL="http://192.168.1.X:3001"

# Optional in dev when frontend runs on Vite (:5173) for OAuth callback redirect.
# FRONTEND_URL="http://localhost:5173"

# Optional runtime tuning.
# PORT=3001
# LOG_LEVEL=info
# NODE_ENV=production

# CORS allowed origin (leave empty to allow all origins; set in production).
# Example: CORS_ORIGIN=http://192.168.1.100:3001
# CORS_ORIGIN=
