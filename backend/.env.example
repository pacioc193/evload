DATABASE_URL="file:./dev.db"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-cryptographically-secure-random-256-bit-hex-string"
TELEGRAM_BOT_TOKEN=""
# Home Assistant OAuth app/client settings.
# If HA_CLIENT_ID is empty, evload falls back to APP_URL and then to http://localhost:3001.
# Set HA_CLIENT_ID explicitly when you want a stable public identifier for Home Assistant.
HA_CLIENT_ID=""
HA_CLIENT_SECRET=""
# APP_URL is used as the OAuth client_id and to build the redirect_uri presented to HA.
# It must be reachable by the Home Assistant server — use the evload machine's LAN IP:
#   APP_URL="http://192.168.1.X:3001"
# If both HA and evload run on the same machine, localhost is fine:
APP_URL="http://localhost:3001"
# FRONTEND_URL is only needed in dev mode so the OAuth callback redirects to the Vite
# dev server (:5173) instead of the backend root. Leave empty in production.
FRONTEND_URL=""
PORT=3001
