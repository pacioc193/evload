DATABASE_URL="file:./dev.db"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-cryptographically-secure-random-256-bit-hex-string"
TELEGRAM_BOT_TOKEN=""
# Home Assistant OAuth app/client settings.
# If HA_CLIENT_ID is empty, evload falls back to APP_URL and then to http://localhost:3001.
# Set HA_CLIENT_ID explicitly when you want a stable public identifier for Home Assistant.
HA_CLIENT_ID=""
HA_CLIENT_SECRET=""
APP_URL="http://localhost:3001"
PORT=3001
