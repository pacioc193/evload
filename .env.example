# ============================================================
# EVLOAD ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and customize for your environment
# This file is committed to repository as a template.
# .env file is in .gitignore (not committed)

# ============================================================
# RUNTIME & INFRASTRUCTURE
# ============================================================

# Server port (default: 3001)
PORT=3001

# Node environment (development | production)
NODE_ENV=development

# Logging level (debug | info | warn | error)
LOG_LEVEL=info

# Database URL (SQLite file path or connection string)
DATABASE_URL=file:./dev.db

# Public URL accessible by frontend and OAuth callbacks
# Leave empty to auto-detect (LAN IP / mDNS hostname)
# Example: http://evload.local:3001 or http://192.168.1.100:3001
APP_URL=

# Path to configuration YAML file (default: ./config.yaml)
CONFIG_PATH=./config.yaml

# ============================================================
# SECURITY
# ============================================================

# JWT secret (auto-generated on first run if not set)
# In production: use a long random hex string (min 64 chars)
# JWT_SECRET=replace-with-a-cryptographically-secure-random-256-bit-hex-string

# CORS allowed origin in production (leave empty to allow all origins)
# In production set to the exact URL of the frontend, e.g.:
# CORS_ORIGIN=http://192.168.1.100:3001
CORS_ORIGIN=
